# Copy this file to .env and fill in your Supabase project values.
# You can find these in the Supabase dashboard under: Project Settings → API.
#
# Pixafé runs in "offline scaffold mode" if these are missing — the canvas + UI
# still work, but anonymous auth, persistence, and presence are disabled.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
